# Supabase — copy this file to .env.local and fill in your project values.
# Project settings → API in the Supabase dashboard.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — service role key. NEVER expose to the browser.
# Used by the contact API route, the admin panel, and the seed script.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to sign the admin session cookie (custom auth).
# Use a long random string, e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars
